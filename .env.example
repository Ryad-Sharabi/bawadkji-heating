# انسخ هذا الملف إلى .env واملأ القيم (لا ترفع .env إلى Git)
# Copy this file to .env and fill in the values (do not commit .env)

# MySQL – غيّر USER و PASSWORD و DATABASE حسب إعداداتك
# MySQL – change USER, PASSWORD and DATABASE to match your setup

# مثال اتصال محلي:
# DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/bawadkji"

# مع SSL (استضافة بعيدة):
# DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE?sslmode=require"

DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/bawadkji"

# سري لتوقيع جلسة لوحة التحكم (غيّره في الإنتاج)
AUTH_SECRET="your-random-secret-at-least-32-chars"
